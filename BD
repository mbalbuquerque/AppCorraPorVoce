CREATE database corra_por_voce;
use corra_por_voce;
CREATE TABLE usuarios (
    id SERIAL PRIMARY KEY,
    nome VARCHAR(100),
    altura DECIMAL(3, 2) -- Ex: 1.75
);


CREATE TABLE atividades (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    usuario_id INTEGER,
    tipo VARCHAR(20), -- 'Corrida' ou 'Caminhada'
    distancia DECIMAL(5, 2), 
    duracao TIME, -- No MySQL usamos TIME para durações de até 838 horas
    data_treino DATETIME DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_usuario_atividades FOREIGN KEY (usuario_id) REFERENCES usuarios(id)
);

CREATE TABLE medicoes_peso (
    id INT AUTO_INCREMENT PRIMARY KEY,
    usuario_id INTEGER,
    nome VARCHAR(100),
    peso DECIMAL(5, 2),
    data_medicao DATE DEFAULT (CURRENT_DATE), -- No MySQL 8.0+ usa-se parênteses
    CONSTRAINT fk_usuario_peso FOREIGN KEY (usuario_id) REFERENCES usuarios(id)
);

