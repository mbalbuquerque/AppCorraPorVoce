    u.nome,
    (SELECT peso FROM medicoes_peso WHERE usuario_id = u.id ORDER BY data_medicao ASC LIMIT 1) AS peso_inicial,
    (SELECT peso FROM medicoes_peso WHERE usuario_id = u.id ORDER BY data_medicao DESC LIMIT 1) AS peso_atual,
    (SELECT peso FROM medicoes_peso WHERE usuario_id = u.id ORDER BY data_medicao DESC LIMIT 1) - 
    (SELECT peso FROM medicoes_peso WHERE usuario_id = u.id ORDER BY data_medicao ASC LIMIT 1) AS diferenca_total
