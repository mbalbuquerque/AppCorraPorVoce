SELECT 
    tipo,
    COUNT(*) AS total_treinos,
    SUM(distancia) AS km_totais,
    -- Cálculo do Pace Médio (Minutos por Quilômetro)
    SEC_TO_TIME(SUM(TIME_TO_SEC(duracao)) / SUM(distancia)) AS pace_medio
FROM atividades
WHERE usuario_id = 1
GROUP BY tipo;

CREATE OR REPLACE VIEW v_resumo_treinos AS
SELECT 
    u.nome AS atleta,
    a.tipo,
    COUNT(a.id) AS qtd_treinos,
    SUM(a.distancia) AS km_totais,
    SEC_TO_TIME(SUM(TIME_TO_SEC(a.duracao))) AS tempo_total,
    -- Calcula o Pace (Tempo médio por KM)
    SEC_TO_TIME(SUM(TIME_TO_SEC(a.duracao)) / SUM(a.distancia)) AS pace_medio
FROM atividades a
JOIN usuarios u ON a.usuario_id = u.id
GROUP BY u.nome, a.tipo;

CREATE OR REPLACE VIEW v_historico_imc AS
SELECT 
    u.nome,
    m.peso,
    u.altura,
    ROUND(m.peso / (u.altura * u.altura), 2) AS imc,
    m.data_medicao
FROM medicoes_peso m
JOIN usuarios u ON m.usuario_id = u.id;

DELIMITER $$

CREATE TRIGGER tg_valida_peso
BEFORE INSERT ON medicoes_peso
FOR EACH ROW
BEGIN
    IF NEW.peso <= 0 OR NEW.peso > 400 THEN
        SIGNAL SQLSTATE '45000' 
        SET MESSAGE_TEXT = 'Erro: Peso inserido está fora dos limites realistas (0-400kg).';
    END IF;
END$$

